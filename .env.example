# =============================================================================
# SyncFit by Synclat — environment variables
# =============================================================================
# Copy this file to .env.local and fill in your keys:
#     cp .env.example .env.local
#
# SECURITY: .env.local is gitignored. Never commit real API keys.
# All keys below (except NEXT_PUBLIC_APP_NAME) are SERVER-SIDE ONLY and are
# never exposed to the browser — SyncFit calls every provider from Next.js
# server routes.
#
# DEMO MODE: The app is fully functional with NO keys set. Missing keys simply
# switch the relevant surface into clearly-labeled demo mode.
# =============================================================================

# --- Required for live data (optional in demo mode) -------------------------

# Musixmatch — the required hackathon music data layer.
# Used for track search, metadata, language/explicit flags, and lyric CONTEXT.
# Compliance: SyncFit never stores, caches, or displays full lyrics.
MUSIXMATCH_API_KEY=

# OpenRouter — the AI reasoning layer that produces the SyncFit analysis JSON.
OPENROUTER_API_KEY=

# Optional: override the default OpenRouter model.
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --- Optional partner APIs (safe placeholders if unset) ---------------------

# Songstats — market signal (artist/track momentum) + trending data. Optional.
SONGSTATS_API_KEY=

# ElevenLabs — text-to-speech (server-side only). Optional; when set, SyncFit can
# read the pitch summary + score results aloud.
ELEVENLABS_API_KEY=

# Spotify — Client ID + Secret (server-side only). Optional. Two uses:
#   1) App-level metadata fallback (genre / BPM / popularity) + link resolving.
#   2) FULL-TRACK playback in the footer player via the Web Playback SDK — each
#      listener clicks "Connect Spotify" and must have Spotify PREMIUM; everyone
#      else falls back to the keyless 30s preview.
# For full-track playback, register these Redirect URIs in your Spotify app
# (dashboard → Edit Settings → Redirect URIs), matching where the app is served:
#   http://127.0.0.1:3000/api/spotify/callback   (local dev — use 127.0.0.1, not localhost)
#   https://<your-domain>/api/spotify/callback   (production)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Storage (optional) -----------------------------------------------------
# Vercel Blob — when set, saved reports & pitch projects persist durably across
# serverless instances instead of the ephemeral /tmp fallback. Normally
# auto-provisioned by Vercel Blob; you rarely set this by hand. Informational.
# BLOB_READ_WRITE_TOKEN=

# --- Public (safe to expose to the browser) ---------------------------------
NEXT_PUBLIC_APP_NAME=SyncFit by Synclat

# --- Roadmap (not implemented) ----------------------------------------------
# Cyanite could later add advanced sonic tagging (mood / energy / tempo /
# instrumentation / similarity search). No code reads a key for it yet.
